;; kotoba-lang/kisekae — VRM character editor domain library (ADR-2607071610).
;; The editor LAYER over kotoba-lang/org-vrmc-vrm's existing engine (parse/
;; decompose/compose/export): character-spec EDN document, pure edit ops +
;; undo/redo, spec -> .vrm build, kotobase-shaped persistence contract.
;; Pure .cljc, one dependency, no UI here — the consuming app supplies
;; viewport (canvaskit), preview render (kami-webgpu), and controls
;; (kotoba-lang/editor's walk-and-surface).
{:paths ["src"]

 :deps {org.clojure/clojure {:mvn/version "1.12.0"}
        ;; The engine: VRM parse/decompose/compose/export, zero-dep .cljc.
        ;; Sibling-path convention, same as every kotoba-lang consumer.
        kotoba-lang/org-vrmc-vrm {:local/root "../org-vrmc-vrm"}
        kotoba-lang/kotoba-lang {:local/root "../kotoba-lang"}}

 :aliases
 {:lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts ["-m" "clj-kondo.main" "--lint" "src" "test"
                     "--fail-level" "error"]}}}
